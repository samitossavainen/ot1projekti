<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mokkikodit.controller.MainController">
    <center>
        <StackPane fx:id="contentArea" prefHeight="150.0" prefWidth="200.0" BorderPane.alignment="CENTER" />
    </center>
    <left>
        <VBox style="-fx-background-color: #4A5D23;" BorderPane.alignment="CENTER">
            <children>
                <VBox alignment="CENTER" maxHeight="150.0" prefHeight="150.0" prefWidth="100.0" spacing="10.0" style="-fx-background-color: #D8E4BC;">
                    <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                    </padding>
                    <children>
                        <Label text="Mökkikodit" textFill="#574420ef">
                            <font>
                                <Font name="Georgia Bold" size="24.0" />
                            </font>
                            <padding>
                                <Insets top="10.0" />
                            </padding>
                        </Label>
                        <ImageView fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@../images/logo.png" />
                            </image>
                        </ImageView>
                    </children>
                </VBox>
                <VBox alignment="TOP_CENTER" spacing="15.0" style="-fx-background-color: #D8E4BC;" VBox.vgrow="ALWAYS">
                    <children>
                        <HBox alignment="CENTER" maxHeight="5.0" prefWidth="200.0">
                            <children>
                                <Region maxHeight="1.5" prefHeight="1.5" prefWidth="190.0" style="-fx-background-color: #9DAE7A;;" />
                            </children>
                        </HBox>
                        <Button fx:id="btnVaraukset" maxWidth="1.7976931348623157E308" onAction="#showVaraukset" prefHeight="40.0" styleClass="nav-button" text="Varaukset" />
                        <Button fx:id="btnMokit" maxWidth="1.7976931348623157E308" onAction="#showMokit" prefHeight="40.0" styleClass="nav-button" text="Mökit" />
                        <Button fx:id="btnAsiakkaat" maxWidth="1.7976931348623157E308" onAction="#showAsiakkaat" prefHeight="40.0" styleClass="nav-button" text="Asiakkaat" />
                        <Button fx:id="btnLaskut" maxWidth="1.7976931348623157E308" onAction="#showLaskutus" prefHeight="40.0" styleClass="nav-button" text="Laskut" />
                        <Button fx:id="btnRaportit" maxWidth="1.7976931348623157E308" onAction="#showRaportit" prefHeight="40.0" styleClass="nav-button" text="Raportit" />
                    </children>
                    <padding>
                        <Insets bottom="10.0" top="15.0" />
                    </padding>
                    <opaqueInsets>
                        <Insets />
                    </opaqueInsets>
                </VBox>
            </children>
        </VBox>
    </left>
</BorderPane>
